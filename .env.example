# Copy to Railway → Variables (do NOT commit real keys to git)

# Required — friend's OpenAI account; WordPress never sees this key
OPENAI_API_KEY=sk-...

# Railway sets PORT automatically
PORT=8000

# Production defaults (also set in Dockerfile)
CE_TRANSCRIBE_MODE=openai
CE_ALLOW_YTDLP_DOWNLOAD=false

# Optional tuning
# CE_OPENAI_WHISPER_MODEL=whisper-1
# CE_IMAGE_MODEL=gpt-image-1
# CE_MAX_VISUAL_ASSETS=8
# CE_IMAGE_CONCURRENCY=1

# Client license keys — seed on deploy; edits persist in data/licenses.json via /admin dashboard
# CE_LICENSES={"CE-PHILTECH-001":{"label":"Philtech","max_projects_month":6,"visuals_allowed":true,"active":true,"plan_price":"$100/mo"}}

# Operator dashboard at https://YOUR-API.up.railway.app/admin
# CE_ADMIN_SECRET=your-long-random-secret

# YouTube captions on cloud IPs — Webshare rotating residential (not datacenter)
# CE_WEBSHARE_PROXY_USERNAME=
# CE_WEBSHARE_PROXY_PASSWORD=
